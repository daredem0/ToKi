{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "atlas.schema.json",
    "title": "AtlasMeta",
    "type": "object",
    "required": [
        "image",
        "tile_size",
        "tiles"
    ],
    "properties": {
        "image": {
            "type": "string",
            "description": "Relative path to the image file"
        },
        "tile_size": {
            "type": "array",
            "description": "Pixel size of each tile: [width, height]",
            "items": {
                "type": "integer",
                "minimum": 1
            },
            "minItems": 2,
            "maxItems": 2
        },
        "tiles": {
            "type": "object",
            "description": "Map of tile names to tile information objects",
            "additionalProperties": {
                "type": "object",
                "required": ["position"],
                "properties": {
                    "position": {
                        "type": "array",
                        "description": "Tile grid position: [x, y] (in tile units)",
                        "items": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "minItems": 2,
                        "maxItems": 2
                    },
                    "properties": {
                        "type": "object",
                        "description": "Tile collision and behavior properties",
                        "properties": {
                            "solid": {
                                "type": "boolean",
                                "description": "Whether this tile blocks movement",
                                "default": false
                            },
                            "trigger": {
                                "type": "boolean", 
                                "description": "Whether this tile triggers events when touched",
                                "default": false
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}