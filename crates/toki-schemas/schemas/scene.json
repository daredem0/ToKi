{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/tokkiclient/toki/schemas/scene.json",
  "title": "ToKi Scene",
  "description": "A scene containing entities, maps, and camera settings for the ToKi game engine",
  "type": "object",
  "required": ["name", "maps", "entities"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the scene"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Optional description of the scene"
    },
    "maps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of map names to load in this scene"
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sceneEntity"
      },
      "description": "Array of entities present in the scene"
    },
    "rules": {
      "$ref": "#/definitions/ruleSet",
      "description": "Scene-authored visual rules evaluated by the runtime rule engine"
    },
    "camera_position": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "array",
          "items": {"type": "number"},
          "minItems": 2,
          "maxItems": 2
        }
      ],
      "description": "Optional camera position [x, y]"
    },
    "camera_scale": {
      "type": ["number", "null"],
      "description": "Optional camera scale factor"
    },
    "background_music_track_id": {
      "type": ["string", "null"],
      "description": "Optional background music track id for this scene"
    },
    "anchors": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sceneAnchor"
      },
      "description": "Authored scene anchors such as spawn points"
    },
    "player_entry": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/definitions/scenePlayerEntry" }
      ],
      "description": "Optional scene-authored player entry preview and spawn target"
    }
  },
  "definitions": {
    "scenePlayerEntry": {
      "type": "object",
      "required": ["entity_definition_name", "spawn_point_id"],
      "additionalProperties": false,
      "properties": {
        "entity_definition_name": {
          "type": "string",
          "minLength": 1
        },
        "spawn_point_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sceneAnchor": {
      "type": "object",
      "required": ["id", "kind", "position"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["SpawnPoint"]
        },
        "position": {
          "type": "array",
          "items": {"type": "integer"},
          "minItems": 2,
          "maxItems": 2
        },
        "facing": {
          "type": ["string", "null"],
          "enum": ["Up", "Down", "Left", "Right", null]
        }
      }
    },
    "ruleSet": {
      "type": "object",
      "required": ["rules"],
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/rule"
          },
          "description": "Ordered rules authored for this scene"
        }
      }
    },
    "rule": {
      "type": "object",
      "required": ["id", "trigger", "actions"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable rule identifier"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this rule should execute"
        },
        "priority": {
          "type": "integer",
          "description": "Higher priority rules execute first"
        },
        "once": {
          "type": "boolean",
          "description": "Run only once for this runtime session"
        },
        "trigger": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["OnStart", "OnUpdate", "OnPlayerMove", "OnTrigger"]
            },
            {
              "type": "object",
              "required": ["OnKey"],
              "additionalProperties": false,
              "properties": {
                "OnKey": {
                  "type": "object",
                  "required": ["key"],
                  "additionalProperties": false,
                  "properties": {
                    "key": {
                      "type": "string",
                      "enum": ["Up", "Down", "Left", "Right", "DebugToggle"]
                    }
                  }
                }
              }
            },
            {
              "type": "object",
              "required": ["OnCollision"],
              "additionalProperties": false,
              "properties": {
                "OnCollision": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "entity": {
                      "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/definitions/ruleTarget" }
                      ]
                    }
                  }
                }
              }
            },
            {
              "type": "object",
              "required": ["OnDamaged"],
              "additionalProperties": false,
              "properties": {
                "OnDamaged": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "entity": {
                      "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/definitions/ruleTarget" }
                      ]
                    }
                  }
                }
              }
            },
            {
              "type": "object",
              "required": ["OnDeath"],
              "additionalProperties": false,
              "properties": {
                "OnDeath": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "entity": {
                      "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/definitions/ruleTarget" }
                      ]
                    }
                  }
                }
              }
            },
            {
              "type": "object",
              "required": ["OnInteract"],
              "additionalProperties": false,
              "properties": {
                "OnInteract": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": ["Overlap", "Adjacent", "InFront"]
                    },
                    "entity": {
                      "anyOf": [
                        { "type": "null" },
                        { "$ref": "#/definitions/ruleTarget" }
                      ]
                    }
                  }
                }
              }
            },
            {
              "type": "object",
              "required": ["OnTileEnter"],
              "additionalProperties": false,
              "properties": {
                "OnTileEnter": {
                  "type": "object",
                  "required": ["x", "y"],
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Tile x-coordinate (in tile units, not pixels)"
                    },
                    "y": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Tile y-coordinate (in tile units, not pixels)"
                    }
                  }
                }
              }
            },
            {
              "type": "object",
              "required": ["OnTileExit"],
              "additionalProperties": false,
              "properties": {
                "OnTileExit": {
                  "type": "object",
                  "required": ["x", "y"],
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Tile x-coordinate (in tile units, not pixels)"
                    },
                    "y": {
                      "type": "integer",
                      "minimum": 0,
                      "description": "Tile y-coordinate (in tile units, not pixels)"
                    }
                  }
                }
              }
            }
          ],
          "description": "Event that triggers this rule"
        },
        "conditions": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "enum": ["Always"]
              },
              {
                "type": "object",
                "required": ["TargetExists"],
                "additionalProperties": false,
                "properties": {
                  "TargetExists": {
                    "type": "object",
                    "required": ["target"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["KeyHeld"],
                "additionalProperties": false,
                "properties": {
                  "KeyHeld": {
                    "type": "object",
                    "required": ["key"],
                    "additionalProperties": false,
                    "properties": {
                      "key": {
                        "type": "string",
                        "enum": ["Up", "Down", "Left", "Right", "DebugToggle"]
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["EntityActive"],
                "additionalProperties": false,
                "properties": {
                  "EntityActive": {
                    "type": "object",
                    "required": ["target", "is_active"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" },
                      "is_active": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["HealthBelow"],
                "additionalProperties": false,
                "properties": {
                  "HealthBelow": {
                    "type": "object",
                    "required": ["target", "threshold"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" },
                      "threshold": {
                        "type": "integer"
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["HealthAbove"],
                "additionalProperties": false,
                "properties": {
                  "HealthAbove": {
                    "type": "object",
                    "required": ["target", "threshold"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" },
                      "threshold": {
                        "type": "integer"
                      }
                    }
                  }
                }
              },
              {
                "type": "string",
                "enum": ["TriggerOtherIsPlayer"]
              },
              {
                "type": "object",
                "required": ["EntityIsKind"],
                "additionalProperties": false,
                "properties": {
                  "EntityIsKind": {
                    "type": "object",
                    "required": ["target", "kind"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" },
                      "kind": { "$ref": "#/definitions/entityKind" }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["TriggerOtherIsKind"],
                "additionalProperties": false,
                "properties": {
                  "TriggerOtherIsKind": {
                    "type": "object",
                    "required": ["kind"],
                    "additionalProperties": false,
                    "properties": {
                      "kind": { "$ref": "#/definitions/entityKind" }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["EntityHasTag"],
                "additionalProperties": false,
                "properties": {
                  "EntityHasTag": {
                    "type": "object",
                    "required": ["target", "tag"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" },
                      "tag": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["TriggerOtherHasTag"],
                "additionalProperties": false,
                "properties": {
                  "TriggerOtherHasTag": {
                    "type": "object",
                    "required": ["tag"],
                    "additionalProperties": false,
                    "properties": {
                      "tag": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["HasInventoryItem"],
                "additionalProperties": false,
                "properties": {
                  "HasInventoryItem": {
                    "type": "object",
                    "required": ["target", "item_id", "min_count"],
                    "additionalProperties": false,
                    "properties": {
                      "target": { "$ref": "#/definitions/ruleTarget" },
                      "item_id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "min_count": {
                        "type": "integer",
                        "minimum": 0
                      }
                    }
                  }
                }
              }
            ]
          },
          "description": "Rule conditions supported by runtime evaluator"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ruleAction"
          },
          "description": "Rule action payloads (externally-tagged enum encoding)"
        }
      }
    },
    "ruleTarget": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["Player", "RuleOwner", "TriggerSelf", "TriggerOther"]
        },
        {
          "type": "object",
          "required": ["Entity"],
          "additionalProperties": false,
          "properties": {
            "Entity": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      ]
    },
    "entityKind": {
      "type": "string",
      "enum": ["Player", "Npc", "Item", "Decoration", "Trigger", "Projectile"]
    },
    "ruleAction": {
      "oneOf": [
        {
          "type": "object",
          "required": ["PlaySound"],
          "additionalProperties": false,
          "properties": {
            "PlaySound": {
              "type": "object",
              "required": ["channel", "sound_id"],
              "additionalProperties": false,
              "properties": {
                "channel": {
                  "type": "string",
                  "enum": ["Movement", "Collision"]
                },
                "sound_id": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["PlayMusic"],
          "additionalProperties": false,
          "properties": {
            "PlayMusic": {
              "type": "object",
              "required": ["track_id"],
              "additionalProperties": false,
              "properties": {
                "track_id": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["PlayAnimation"],
          "additionalProperties": false,
          "properties": {
            "PlayAnimation": {
              "type": "object",
              "required": ["target", "state"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "state": {
                  "type": "string",
                  "enum": ["Idle", "Walk"]
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["SetVelocity"],
          "additionalProperties": false,
          "properties": {
            "SetVelocity": {
              "type": "object",
              "required": ["target", "velocity"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "velocity": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  },
                  "minItems": 2,
                  "maxItems": 2
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["Spawn"],
          "additionalProperties": false,
          "properties": {
            "Spawn": {
              "type": "object",
              "required": ["entity_type", "position"],
              "additionalProperties": false,
              "properties": {
                "entity_type": {
                  "type": "string",
                  "enum": ["PlayerLikeNpc", "Npc", "Item", "Decoration", "Trigger"]
                },
                "position": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  },
                  "minItems": 2,
                  "maxItems": 2
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["DestroySelf"],
          "additionalProperties": false,
          "properties": {
            "DestroySelf": {
              "type": "object",
              "required": ["target"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["SwitchScene"],
          "additionalProperties": false,
          "properties": {
            "SwitchScene": {
              "type": "object",
              "required": ["scene_name", "spawn_point_id"],
              "additionalProperties": false,
              "properties": {
                "scene_name": {
                  "type": "string",
                  "minLength": 1
                },
                "spawn_point_id": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["DamageEntity"],
          "additionalProperties": false,
          "properties": {
            "DamageEntity": {
              "type": "object",
              "required": ["target", "amount"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "amount": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["HealEntity"],
          "additionalProperties": false,
          "properties": {
            "HealEntity": {
              "type": "object",
              "required": ["target", "amount"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "amount": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["AddInventoryItem"],
          "additionalProperties": false,
          "properties": {
            "AddInventoryItem": {
              "type": "object",
              "required": ["target", "item_id", "count"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "item_id": {
                  "type": "string",
                  "minLength": 1
                },
                "count": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["RemoveInventoryItem"],
          "additionalProperties": false,
          "properties": {
            "RemoveInventoryItem": {
              "type": "object",
              "required": ["target", "item_id", "count"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "item_id": {
                  "type": "string",
                  "minLength": 1
                },
                "count": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["SetEntityActive"],
          "additionalProperties": false,
          "properties": {
            "SetEntityActive": {
              "type": "object",
              "required": ["target", "active"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "active": {
                  "type": "boolean"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["TeleportEntity"],
          "additionalProperties": false,
          "properties": {
            "TeleportEntity": {
              "type": "object",
              "required": ["target", "tile_x", "tile_y"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "$ref": "#/definitions/ruleTarget"
                },
                "tile_x": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Tile x-coordinate (in tile units, not pixels)"
                },
                "tile_y": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Tile y-coordinate (in tile units, not pixels)"
                }
              }
            }
          }
        }
      ]
    },
    "sceneEntity": {
      "type": "object",
      "required": ["id", "position", "size", "entity_type", "attributes", "collision_box"],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0,
          "description": "Unique identifier for the entity"
        },
        "position": {
          "type": "array",
          "items": {"type": "integer"},
          "minItems": 2,
          "maxItems": 2,
          "description": "Entity position [x, y]"
        },
        "size": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1},
          "minItems": 2,
          "maxItems": 2,
          "description": "Entity size [width, height]"
        },
        "entity_type": {
          "type": "string",
          "description": "Type of entity (Player, NPC, Item, etc.)"
        },
        "category": {
          "type": "string",
          "description": "Generic category used for editor grouping and authoring"
        },
        "definition_name": {
          "type": ["string", "null"],
          "description": "Source entity definition name used to instantiate this runtime entity"
        },
        "control_role": {
          "type": "string",
          "enum": ["none", "player_character"],
          "description": "Scene-level control role for this entity"
        },
        "attributes": {
          "$ref": "#/definitions/entityAttributes"
        },
        "collision_box": {
          "$ref": "#/definitions/collisionBox"
        },
        "footstep_distance_accumulator": {
          "type": "number",
          "minimum": 0,
          "description": "Current footstep distance accumulator"
        },
        "footstep_trigger_distance": {
          "type": "number",
          "minimum": 0,
          "description": "Distance required to trigger footstep sound"
        },
        "movement_sound_trigger": {
          "type": "string",
          "enum": ["distance", "animation_loop"],
          "description": "How movement sound timing is driven"
        },
        "last_collision_state": {
          "type": "boolean",
          "description": "Last collision state of the entity"
        },
        "movement_sound": {
          "type": ["string", "null"],
          "description": "Sound ID to play when entity moves"
        },
        "collision_sound": {
          "type": ["string", "null"],
          "description": "Sound ID to play when entity collides"
        }
      }
    },
    "entityAttributes": {
      "type": "object",
      "required": ["health", "speed", "solid", "visible", "render_layer", "active", "can_move", "has_inventory"],
      "properties": {
        "health": {
          "type": "integer",
          "minimum": 0,
          "description": "Entity health points"
        },
        "speed": {
          "type": "number",
          "minimum": 0,
          "description": "Entity movement speed"
        },
        "solid": {
          "type": "boolean",
          "description": "Whether entity blocks movement"
        },
        "visible": {
          "type": "boolean",
          "description": "Whether entity is rendered"
        },
        "animation_controller": {
          "$ref": "#/definitions/animationController"
        },
        "render_layer": {
          "type": "integer",
          "description": "Rendering layer (higher values render on top)"
        },
        "active": {
          "type": "boolean",
          "description": "Whether entity is active in the scene"
        },
        "can_move": {
          "type": "boolean",
          "description": "Whether entity can move"
        },
        "has_inventory": {
          "type": "boolean",
          "description": "Whether entity has an inventory system"
        }
      }
    },
    "animationController": {
      "type": "object",
      "required": ["clips", "current_clip_state", "current_frame_index", "frame_timer", "is_finished"],
      "properties": {
        "clips": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "$ref": "#/definitions/animationClip"
            }
          },
          "description": "Animation clips keyed by name"
        },
        "current_clip_state": {
          "type": "string",
          "description": "Currently active animation state"
        },
        "current_frame_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Current frame index in animation"
        },
        "frame_timer": {
          "type": "number",
          "minimum": 0,
          "description": "Timer for current frame"
        },
        "is_finished": {
          "type": "boolean",
          "description": "Whether current animation has finished"
        }
      }
    },
    "animationClip": {
      "type": "object",
      "required": ["state", "atlas_name", "frame_tile_names", "frame_duration_ms", "loop_mode"],
      "properties": {
        "state": {
          "type": "string",
          "description": "Animation state name"
        },
        "atlas_name": {
          "type": "string",
          "description": "Name of atlas containing animation frames"
        },
        "frame_tile_names": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1,
          "description": "Array of tile names for animation frames"
        },
        "frame_duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Duration of each frame in milliseconds"
        },
        "loop_mode": {
          "type": "string",
          "enum": ["Loop", "Once", "PingPong"],
          "description": "How the animation should loop"
        }
      }
    },
    "collisionBox": {
      "type": "object",
      "required": ["offset", "size", "trigger"],
      "properties": {
        "offset": {
          "type": "array",
          "items": {"type": "integer"},
          "minItems": 2,
          "maxItems": 2,
          "description": "Collision box offset from entity position [x, y]"
        },
        "size": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1},
          "minItems": 2,
          "maxItems": 2,
          "description": "Collision box size [width, height]"
        },
        "trigger": {
          "type": "boolean",
          "description": "Whether this is a trigger collision (doesn't block movement)"
        }
      }
    }
  }
}
